-- [ 5. ลูปทำงานฟาร์มเบื้องหลัง ]
local blacklistedCrates = {}
task.spawn(function()
    previouslyLooting = false
    while true do
        task.wait(0.5)
        if getgenv().TheArmory_ScriptId ~= scriptId then break end
        
        if AutoFarmEnabled then
            if isDepositing then
                task.wait(0.5)
                continue
            end
            
            local char = LocalPlayer.Character
            local humanoid = char and char:FindFirstChildOfClass("Humanoid")
            local hrp = char and char:FindFirstChild("HumanoidRootPart")
            
            if not char or not hrp or (humanoid and humanoid.Health <= 0) then
                continue
            end

            -- ตรวจสอบว่ากระเป๋าเต็ม (6/6) หรือไม่ก่อนเริ่มฟาร์ม
            if isInventoryFull() then
                previouslyLooting = false -- รีเซ็ตสถานะเพื่อให้วาร์ปเข้าแมพใหม่เมื่อกลับไปฟาร์ม
                setStatus("<font color='#E74C3C'>🚨 Inventory Full! Teleporting to sell...</font>")
                hrp.CFrame = getLockerCFrame()
                task.wait(0.6)
                
                -- สั่งขายปืนเกรดที่เลือก
                local sold = SellSelectedItems(true)
                task.wait(0.6)
                
                -- ถ้าขายสำเร็จ ไม่ต้องสนใจค่าเศษของใน UI (เช่น 3/6 หรือดีเลย์ของเซิร์ฟเวอร์) ให้ไปเก็บต่อได้เลย
                if sold then
                    setStatus("<font color='#2ECC71'>🟢 Selling complete! Waiting 5s before farming...</font>")
                    task.wait(5.0)
                else
                    -- ตรวจสอบอีกครั้งกรณีไม่ได้ขาย (เช่น ไม่มีของเกรดที่เลือก)
                    if isInventoryFull() then
                        -- ตรวจสอบเผื่อมีของแรร์ให้ฝากล็อกเกอร์
                        local backpack = LocalPlayer:FindFirstChild("Backpack")
                        local hasHighRarity = false
                        if backpack then
                            for _, bpItem in ipairs(backpack:GetChildren()) do
                                if bpItem:IsA("Tool") then
                                    local rarity = GetRarity(bpItem)
                                    if rarity >= MIN_DEPOSIT_RARITY then
                                        hasHighRarity = true
                                        break
                                    end
                                end
                            end
                        end
                        if not hasHighRarity and char then
                            for _, charItem in ipairs(char:GetChildren()) do
                                if charItem:IsA("Tool") then
                                    local rarity = GetRarity(charItem)
                                    if rarity >= MIN_DEPOSIT_RARITY then
                                        hasHighRarity = true
                                        break
                                    end
                                end
                            end
                        end
                        
                        if hasHighRarity then
                            setStatus("<font color='#F1C40F'>🟡 Inventory Full but has Rare Items! Depositing...</font>")
                            DepositLocker()
                            task.wait(0.5)
                        else
                            setStatus("<font color='#E74C3C'>⚠️ Inventory full with kept items! Clear manually.</font>")
                            task.wait(3.0)
                        end
                    else
                        -- ขายเสร็จและกระเป๋าว่างแล้ว ให้รอ 5 วินาทีก่อนกลับไปฟาร์ม
                        setStatus("<font color='#2ECC71'>🟢 Selling complete! Waiting 5s before farming...</font>")
                        task.wait(5.0)
                    end
                end
                continue
            end

            if not previouslyLooting then
                previouslyLooting = true
                setStatus("<font color='#F1C40F'>🟡 Teleporting for ground looting...</font>")
                _G.TeleportToZone() 
                task.wait(2.0)
            end
            
            char = LocalPlayer.Character
            hrp = char and char:FindFirstChild("HumanoidRootPart")
            if not hrp then continue end

            local lootedAny = false
            
            -- 1. เคลียร์และเปิดกล่องก่อน
            local spawnedCrates = workspace:FindFirstChild("SpawnedCrates")
            local crates = spawnedCrates and spawnedCrates:GetChildren() or {}
            
            for _, crate in ipairs(crates) do
                if not AutoFarmEnabled or isDepositing or isInventoryFull() then break end
                if not char or not char.Parent or not hrp or not hrp.Parent then break end
                
                -- ตรวจสอบแบล็คลิสต์กล่องที่เปิดไม่ได้
                if blacklistedCrates[crate] then continue end
                
                local cratePrompt = crate:FindFirstChild("Prompt") 
                    or crate:FindFirstChildWhichIsA("ProximityPrompt") 
                    or crate:FindFirstChildOfClass("ProximityPrompt")
                
                if not cratePrompt then
                    for _, desc in ipairs(crate:GetDescendants()) do
                        if desc:IsA("ProximityPrompt") then
                            cratePrompt = desc
                            break
                        end
                    end
                end
                
                if cratePrompt and cratePrompt.Enabled then
                    local targetPart = crate:IsA("BasePart") and crate or crate:FindFirstChildWhichIsA("BasePart")
                    if targetPart then
                        lootedAny = true
                        setStatus("<font color='#F1C40F'>🟡 Crates: Opening " .. crate.Name .. "...</font>")
                        
                        -- วาร์ปอยู่เหนือกล่องเล็กน้อย 2.5 studs เพื่อเลี่ยงการติดโมเดล/กล้องบั๊กบนโทรศัพท์
                        hrp.CFrame = targetPart.CFrame * CFrame.new(0, 2.5, 0)
                        task.wait(0.4)
                        
                        if not AutoFarmEnabled or isDepositing or isInventoryFull() then break end
                        
                        -- ขั้นตอนที่ 1: กดปุ่มเปิดกล่อง (สูงสุด 5 ครั้ง ห่างกันครั้งละ 0.5 วินาที หรือจนกว่าจะเปิดสำเร็จ)
                        local openedSuccessfully = false
                        for attempt = 1, 5 do
                            if not crate or not crate.Parent or not AutoFarmEnabled or isDepositing or not cratePrompt.Enabled then break end
                            FireLootPrompt(cratePrompt)
                            task.wait(0.5)
                            if not cratePrompt.Enabled then
                                openedSuccessfully = true
                                break
                            end
                        end
                        
                        -- หากพยายามกดเปิด 5 ครั้งแล้วยังไม่เปิด (ปุ่มยังอยู่และไม่เข้าสถานะเปิดสำเร็จ)
                        -- ให้แบล็คลิสต์กล่องนี้ไว้เพื่อข้ามในลูปครั้งต่อไป ไม่ต้องค้างอยู่ตรงนี้
                        if cratePrompt and cratePrompt.Enabled and not openedSuccessfully then
                            blacklistedCrates[crate] = true
                            setStatus("<font color='#E74C3C'>❌ Crate Locked! Blacklisting...</font>")
                            task.wait(0.4)
                            continue
                        end
                        
                        -- ขั้นตอนที่ 2: รอให้ของสปอว์นออกมาจากกล่อง (เช็คใน workspace.SpawnedItems)
                        local spawnedItemPrompt = nil
                        local spawnedItem = nil
                        
                        for i = 1, 15 do -- รอสูงสุด 3.0 วินาที
                            if not AutoFarmEnabled or isDepositing or not crate or not crate.Parent then break end
                            
                            local spawnedItems = workspace:FindFirstChild("SpawnedItems")
                            if spawnedItems then
                                for _, item in ipairs(spawnedItems:GetChildren()) do
                                    local itemPart = item:IsA("BasePart") and item or item:FindFirstChildWhichIsA("BasePart")
                                    if itemPart and (itemPart.Position - targetPart.Position).Magnitude <= 12 then
                                        local prompt = item:FindFirstChild("Prompt") or item:FindFirstChildWhichIsA("ProximityPrompt")
                                        if prompt and prompt.Enabled then
                                            -- ข้ามไอเทมประเภทคีย์การ์ด/ยาสลบ
                                            if not (AutoDropUtilities and isUtilityItem(item)) then
                                                spawnedItem = item
                                                spawnedItemPrompt = prompt
                                                break
                                            end
                                        end
                                    end
                                end
                            end
                            if spawnedItemPrompt then break end
                            task.wait(0.2)
                        end
                        
                        -- ขั้นตอนที่ 3: ถ้าเจอของที่ดรอปออกมาจากกล่อง ให้เก็บทันที
                        if spawnedItemPrompt and spawnedItem then
                            setStatus("<font color='#F1C40F'>🟡 Crates: Taking Spawned Item...</font>")
                            local itemPart = spawnedItem:IsA("BasePart") and spawnedItem or spawnedItem:FindFirstChildWhichIsA("BasePart")
                            if itemPart then
                                hrp.CFrame = itemPart.CFrame * CFrame.new(0, 1.5, 0)
                                task.wait(0.3)
                                
                                local inventoryGUI = PlayerGui:FindFirstChild("InventoryGUI")
                                local frame = inventoryGUI and inventoryGUI:FindFirstChild("Frame")
                                local display = frame and frame:FindFirstChild("FillDisplay")
                                local oldText = display and display.Text or ""
                                local looted = false
                                
                                for attempt = 1, 5 do
                                    if not spawnedItem or not spawnedItem.Parent or not AutoFarmEnabled or isDepositing or not spawnedItemPrompt.Enabled or isInventoryFull() then break end
                                    FireLootPrompt(spawnedItemPrompt)
                                    task.wait(0.5)
                                    if not spawnedItem or not spawnedItem.Parent then
                                        looted = true
                                        break
                                    end
                                end
                                
                                if looted then
                                    -- รอให้ UI อัปเดตข้อมูลจำนวนไอเทมสูงสุด 1.5 วินาที เพื่อป้องกันความล่าช้าของเน็ตเวิร์ก
                                    local startWait = tick()
                                    while tick() - startWait < 1.5 do
                                        if display and display.Text ~= oldText then
                                            break
                                        end
                                        task.wait(0.1)
                                    end
                                end
                            end
                        end
                        
                        -- ตรวจสอบว่ามีของแรร์เข้าตัวจากการเปิดกล่องหรือไม่
                        local backpack = LocalPlayer:FindFirstChild("Backpack")
                        local hasHighRarity = false
                        if backpack then
                            for _, bpItem in ipairs(backpack:GetChildren()) do
                                if bpItem:IsA("Tool") then
                                    local rarity = GetRarity(bpItem)
                                    if rarity >= MIN_DEPOSIT_RARITY then
                                        hasHighRarity = true
                                        break
                                    end
                                end
                            end
                        end
                        
                        if hasHighRarity and AutoFarmEnabled then
                            setStatus("<font color='#F1C40F'>🟡 Found Rare Item! Depositing...</font>")
                            DepositLocker()
                        end
                        task.wait(0.2)
                    end
                end
            end
            
            -- 2. เคลียร์ไอเทมดรอปบนพื้น
            local spawnedItems = workspace:FindFirstChild("SpawnedItems")
            local items = spawnedItems and spawnedItems:GetChildren() or {}
            
            setStatus(string.format("<font color='#F1C40F'>🟡 Looting: Scanning %d drops...</font>", #items))
            
            for _, item in ipairs(items) do
                if not AutoFarmEnabled or isDepositing or isInventoryFull() then break end
                if not char or not char.Parent or not hrp or not hrp.Parent then break end
                
                -- ข้ามคีย์การ์ดและยาสลบ
                if AutoDropUtilities and isUtilityItem(item) then
                    continue
                end
                
                local itemPrompt = item:FindFirstChild("Prompt") or item:FindFirstChildWhichIsA("ProximityPrompt")
                if item and item.Parent and itemPrompt and itemPrompt.Enabled then
                    local targetPart = item:IsA("BasePart") and item or item:FindFirstChildWhichIsA("BasePart")
                    
                    if targetPart then
                        lootedAny = true
                        
                        -- วาร์ปอยู่เหนือของเล็กน้อย 1.5 studs เลี่ยงการจมดิน
                        hrp.CFrame = targetPart.CFrame * CFrame.new(0, 1.5, 0)
                        task.wait(0.4)
                        
                        if not AutoFarmEnabled or isDepositing then break end
                        
                        local inventoryGUI = PlayerGui:FindFirstChild("InventoryGUI")
                        local frame = inventoryGUI and inventoryGUI:FindFirstChild("Frame")
                        local display = frame and frame:FindFirstChild("FillDisplay")
                        local oldText = display and display.Text or ""
                        local looted = false
                        
                        -- กดปุ่ม E สูงสุด 5 ครั้ง ห่างกันครั้งละ 0.5 วินาที
                        for attempt = 1, 5 do
                            if not item or not item.Parent or not AutoFarmEnabled or isDepositing or not itemPrompt.Enabled or isInventoryFull() then break end
                            FireLootPrompt(itemPrompt)
                            task.wait(0.5)
                            if not item or not item.Parent then
                                looted = true
                                break
                            end
                        end
                        
                        if looted then
                            -- รอให้ UI อัปเดตข้อมูลจำนวนไอเทมสูงสุด 1.5 วินาที เพื่อป้องกันความล่าช้าของเน็ตเวิร์ก
                            local startWait = tick()
                            while tick() - startWait < 1.5 do
                                if display and display.Text ~= oldText then
                                    break
                                end
                                task.wait(0.1)
                            end
                            
                            -- แสดงว่าเก็บสำเร็จ ให้สแกนหาของระดับแรร์ในกระเป๋าทันที
                            local backpack = LocalPlayer:FindFirstChild("Backpack")
                            local hasHighRarity = false
                            if backpack then
                                for _, bpItem in ipairs(backpack:GetChildren()) do
                                    if bpItem:IsA("Tool") then
                                        local rarity = GetRarity(bpItem)
                                        if rarity >= MIN_DEPOSIT_RARITY then
                                            hasHighRarity = true
                                            break
                                        end
                                    end
                                end
                            end
                            
                            if hasHighRarity and AutoFarmEnabled then
                                setStatus("<font color='#F1C40F'>🟡 Found Rare Item! Depositing...</font>")
                                DepositLocker()
                            end
                        else
                            if item and item.Parent then
                                setStatus("<font color='#E74C3C'>❌ Stuck! Skipping...</font>")
                                task.wait(0.3)
                            end
                        end
                        task.wait(0.2)
                    end
                end
            end
            
            -- ตรวจเช็คขั้นสุดท้ายเพื่อฝากของแรร์ที่อาจหลงเหลือ
            local backpack = LocalPlayer:FindFirstChild("Backpack")
            local hasHighRarity = false
            if backpack then
                for _, bpItem in ipairs(backpack:GetChildren()) do
                    if bpItem:IsA("Tool") then
                        local rarity = GetRarity(bpItem)
                        if rarity >= MIN_DEPOSIT_RARITY then
                            hasHighRarity = true
                            break
                        end
                    end
                end
            end
            
            if hasHighRarity and AutoFarmEnabled then
                DepositLocker()
            end
            
            -- หลังจากลูปเก็บทุกอย่างเสร็จสิ้นในรอบนั้น ให้กลับมารอที่ล็อกเกอร์เพื่อความปลอดภัย
            if lootedAny and hrp and hrp.Parent and AutoFarmEnabled and not isDepositing then
                hrp.CFrame = getLockerCFrame()
                task.wait(0.5)
            end
            
            if AutoSellEnabled and AutoFarmEnabled then
                SellSelectedItems()
            end
            
            if AutoFarmEnabled then 
                setStatus("<font color='#2ECC71'>🟢 Auto Farm: Scanning...</font>") 
            end
        else
            previouslyLooting = false
            setStatus("<font color='#7F8C8D'>⚪ Auto Farm: Disabled</font>")
        end
    end
end)

