-- [ 5. ลูปทำงานฟาร์มเบื้องหลัง ]
task.spawn(function()
    local previouslyLooting = false
    while true do
        task.wait(0.5)
        if getgenv().TheArmory_ScriptId ~= scriptId then break end
        
        if AutoFarmEnabled then
            if isDepositing then
                task.wait(0.5)
                continue
            end
            
            local char = LocalPlayer.Character
            local humanoid = char and char:FindFirstChildOfClass("Humanoid")
            local hrp = char and char:FindFirstChild("HumanoidRootPart")
            
            if not char or not hrp or (humanoid and humanoid.Health <= 0) then
                continue
            end

            if not previouslyLooting then
                previouslyLooting = true
                setStatus("<font color='#F1C40F'>🟡 Teleporting for ground looting...</font>")
                _G.TeleportToZone() 
                task.wait(2.0)
            end
            
            char = LocalPlayer.Character
            hrp = char and char:FindFirstChild("HumanoidRootPart")
            if not hrp then continue end

            local lootedAny = false
            
            -- 1. เคลียร์และเปิดกล่องก่อน
            local spawnedCrates = workspace:FindFirstChild("SpawnedCrates")
            local crates = spawnedCrates and spawnedCrates:GetChildren() or {}
            
            for _, crate in ipairs(crates) do
                if not AutoFarmEnabled or isDepositing then break end
                if not char or not char.Parent or not hrp or not hrp.Parent then break end
                
                local cratePrompt = crate:FindFirstChild("Prompt") 
                    or crate:FindFirstChildWhichIsA("ProximityPrompt") 
                    or crate:FindFirstChildOfClass("ProximityPrompt")
                
                if not cratePrompt then
                    for _, desc in ipairs(crate:GetDescendants()) do
                        if desc:IsA("ProximityPrompt") then
                            cratePrompt = desc
                            break
                        end
                    end
                end
                
                if cratePrompt and cratePrompt.Enabled then
                    local targetPart = crate:IsA("BasePart") and crate or crate:FindFirstChildWhichIsA("BasePart")
                    if targetPart then
                        lootedAny = true
                        setStatus("<font color='#F1C40F'>🟡 Crates: Opening " .. crate.Name .. "...</font>")
                        
                        hrp.CFrame = targetPart.CFrame
                        task.wait(0.4)
                        
                        if not AutoFarmEnabled or isDepositing then break end
                        
                        -- กดปุ่ม E สูงสุด 5 ครั้ง ห่างกันครั้งละ 0.5 วินาที
                        for attempt = 1, 5 do
                            if not crate or not crate.Parent or not AutoFarmEnabled or isDepositing then break end
                            FireLootPrompt(cratePrompt)
                            task.wait(0.5)
                        end
                        
                        -- ตรวจสอบว่ามีของแรร์เข้าตัวจากการเปิดกล่องหรือไม่
                        local backpack = LocalPlayer:FindFirstChild("Backpack")
                        local hasHighRarity = false
                        if backpack then
                            for _, bpItem in ipairs(backpack:GetChildren()) do
                                if bpItem:IsA("Tool") then
                                    local rarity = GetRarity(bpItem)
                                    if rarity >= MIN_DEPOSIT_RARITY then
                                        hasHighRarity = true
                                        break
                                    end
                                end
                            end
                        end
                        
                        if hasHighRarity and AutoFarmEnabled then
                            setStatus("<font color='#F1C40F'>🟡 Found Rare Item! Depositing...</font>")
                            DepositLocker()
                        end
                        
                        if hrp and hrp.Parent then
                            hrp.CFrame = getLockerCFrame()
                        end
                        task.wait(0.4)
                    end
                end
            end
            
            -- 2. เคลียร์ไอเทมดรอปบนพื้น
            local spawnedItems = workspace:FindFirstChild("SpawnedItems")
            local items = spawnedItems and spawnedItems:GetChildren() or {}
            
            setStatus(string.format("<font color='#F1C40F'>🟡 Looting: Scanning %d drops...</font>", #items))
            
            for _, item in ipairs(items) do
                if not AutoFarmEnabled or isDepositing then break end
                if not char or not char.Parent or not hrp or not hrp.Parent then break end
                
                local itemPrompt = item:FindFirstChild("Prompt") or item:FindFirstChildWhichIsA("ProximityPrompt")
                if item and item.Parent and itemPrompt and itemPrompt.Enabled then
                    local targetPart = item:IsA("BasePart") and item or item:FindFirstChildWhichIsA("BasePart")
                    
                    if targetPart then
                        lootedAny = true
                        
                        hrp.CFrame = targetPart.CFrame
                        task.wait(0.4)
                        
                        if not AutoFarmEnabled or isDepositing then break end
                        
                        -- กดปุ่ม E สูงสุด 5 ครั้ง ห่างกันครั้งละ 0.5 วินาที
                        for attempt = 1, 5 do
                            if not item or not item.Parent or not AutoFarmEnabled or isDepositing then break end
                            FireLootPrompt(itemPrompt)
                            task.wait(0.5)
                        end
                        
                        if item and item.Parent then
                            setStatus("<font color='#E74C3C'>❌ Stuck! Skipping...</font>")
                            task.wait(0.3)
                        else
                            -- แสดงว่าเก็บสำเร็จ ให้สแกนหาของระดับแรร์ในกระเป๋าทันที
                            local backpack = LocalPlayer:FindFirstChild("Backpack")
                            local hasHighRarity = false
                            if backpack then
                                for _, bpItem in ipairs(backpack:GetChildren()) do
                                    if bpItem:IsA("Tool") then
                                        local rarity = GetRarity(bpItem)
                                        if rarity >= MIN_DEPOSIT_RARITY then
                                            hasHighRarity = true
                                            break
                                        end
                                    end
                                end
                            end
                            
                            if hasHighRarity and AutoFarmEnabled then
                                setStatus("<font color='#F1C40F'>🟡 Found Rare Item! Depositing...</font>")
                                DepositLocker()
                            end
                        end
                        
                        if hrp and hrp.Parent then
                            hrp.CFrame = getLockerCFrame()
                        end
                        task.wait(0.4)
                    end
                end
            end
            
            -- ตรวจเช็คขั้นสุดท้ายเพื่อฝากของแรร์ที่อาจหลงเหลือ
            local backpack = LocalPlayer:FindFirstChild("Backpack")
            local hasHighRarity = false
            if backpack then
                for _, bpItem in ipairs(backpack:GetChildren()) do
                    if bpItem:IsA("Tool") then
                        local rarity = GetRarity(bpItem)
                        if rarity >= MIN_DEPOSIT_RARITY then
                            hasHighRarity = true
                            break
                        end
                    end
                end
            end
            
            if hasHighRarity and AutoFarmEnabled then
                DepositLocker()
            end
            
            if AutoSellEnabled and AutoFarmEnabled then
                SellSelectedItems()
            end
            
            if AutoFarmEnabled then 
                setStatus("<font color='#2ECC71'>🟢 Auto Farm: Scanning...</font>") 
            end
        else
            previouslyLooting = false
            setStatus("<font color='#7F8C8D'>⚪ Auto Farm: Disabled</font>")
        end
    end
end)

-- [ 6. ลูปตรวจสอบความปลอดภัยระดับแรร์ออโต้ (Global Auto-Deposit Watcher) ]
task.spawn(function()
    while true do
        task.wait(0.2)
        if getgenv().TheArmory_ScriptId ~= scriptId then break end
        
        local char = LocalPlayer.Character
        local backpack = LocalPlayer:FindFirstChild("Backpack")
        local humanoid = char and char:FindFirstChildOfClass("Humanoid")
        
        if char and backpack and humanoid and humanoid.Health > 0 and not isDepositing then
            local hasHighRarity = false
            
            -- ตรวจสอบใน Backpack
            for _, item in ipairs(backpack:GetChildren()) do
                if item:IsA("Tool") then
                    local rarity = GetRarity(item)
                    if rarity >= MIN_DEPOSIT_RARITY then
                        hasHighRarity = true
                        break
                    end
                end
            end
            
            -- ตรวจสอบใน Character (เผื่อติดตั้งใช้งานอยู่)
            if not hasHighRarity then
                for _, item in ipairs(char:GetChildren()) do
                    if item:IsA("Tool") then
                        local rarity = GetRarity(item)
                        if rarity >= MIN_DEPOSIT_RARITY then
                            hasHighRarity = true
                            break
                        end
                    end
                end
            end
            
            if hasHighRarity then
                setStatus("<font color='#E74C3C'>🚨 Safe Item Detected! Teleporting to Safe Locker...</font>")
                DepositLocker()
            end
        end
    end
end)

