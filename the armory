    local inSafe = false
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    if hrp then
        local lockerCF = getLockerCFrame()
        if (hrp.Position - lockerCF.Position).Magnitude < 200 then
            inSafe = true
        end
    end

    if inSafe then
        local weaponCount = 0
        local totalItems = 0
        
        if backpack then
            for _, item in ipairs(backpack:GetChildren()) do
                if item:IsA("Tool") then
                    totalItems = totalItems + 1
                    local category = item:GetAttribute("Category")
                    if category == "Weapon" then
                        weaponCount = weaponCount + 1
                    end
                end
            end
        end
        if char then
            for _, item in ipairs(char:GetChildren()) do
                if item:IsA("Tool") then
                    totalItems = totalItems + 1
                    local category = item:GetAttribute("Category")
                    if category == "Weapon" then
                        weaponCount = weaponCount + 1
                    end
                end
            end
        end
        
        local maxCapacity = 6
        local inventoryGUI = PlayerGui:FindFirstChild("InventoryGUI")
        local frame = inventoryGUI and inventoryGUI:FindFirstChild("Frame")
        local display = frame and frame:FindFirstChild("FillDisplay")
        if display then
            local _, max = display.Text:match("(%d+)/(%d+)")
