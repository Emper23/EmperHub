local function isUtilityItem(item)
    if not item then return false end
    local model = item:FindFirstChildOfClass("Model") or item:FindFirstChildWhichIsA("Model")
    if model then
        local name = model.Name:lower()
        if name:find("solution") or name:find("keycard") or name:find("key") then
            return true
        end
    end
    local itemName = item.Name:lower()
    if itemName:find("solution") or itemName:find("keycard") or itemName:find("key") then
        return true
    end
    return false
end

