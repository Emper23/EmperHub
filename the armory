-- 📍 พิกัดตู้ล็อกเกอร์จากโมเดลในแมพ (Interactible ช่องที่ 6)
local function getLockerCFrame()
    local target = workspace:FindFirstChild("Interactible") and workspace.Interactible:GetChildren()[6]
    if target then
        if target:IsA("BasePart") then
            return target.CFrame
        elseif target:IsA("Model") then
            return target:GetPivot()
        end
    end
    return CFrame.new(
        -56.1436501, 5.868999, 109.762741, 
        0.970621407, -1.13886649e-07, -0.240611941, 
        1.20918884e-07, 1, 1.44622936e-08, 
        0.240611941, -4.31319371e-08, 0.970621407
    )
end

