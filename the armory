-- [ 8. ลูปทิ้งคีย์การ์ดและยาสลบอัตโนมัติ (Global Auto-Drop Utilities Watcher) ]
task.spawn(function()
    while true do
        task.wait(1.0)
        if getgenv().TheArmory_ScriptId ~= scriptId then break end
        
        if AutoDropUtilities then
            -- 1. ดรอปไอเทมประเภทคีย์การ์ด/ยาสลบใน Dungeon Inventory (ผ่านระบบจำลองกดปุ่มทิ้งของเกม)
            pcall(function()
                local inventoryGUI = PlayerGui:FindFirstChild("InventoryGUI")
                local frame = inventoryGUI and inventoryGUI:FindFirstChild("Frame")
                if frame then
                    for _, child in ipairs(frame:GetChildren()) do
                        if child.Name == "Prefab" then
                            local title = child:GetAttribute("TooltipTitle") 
                                or (child:FindFirstChild("TextLabel", true) and child:FindFirstChild("TextLabel", true).Text)
                            if title then
                                local nameLower = title:lower()
                                if nameLower:find("keycard") or nameLower:find("solution") or nameLower:find("key") then
                                    local button = child:FindFirstChild("Button") or child:FindFirstChildWhichIsA("ImageButton")
                                    if button then
                                        safeClick(button)
                                        print("Dropped dungeon utility item via UI: " .. title)
                                        task.wait(0.2)
                                    end
                                end
                            end
                        end
                    end
                end
            end)
            
            -- 2. ดรอปไอเทมประเภทคีย์การ์ด/ยาสลบใน Backpack / Character ของผู้เล่น
            local backpack = LocalPlayer:FindFirstChild("Backpack")
            local char = LocalPlayer.Character
            
            local function checkAndDrop(item)
                if item:IsA("Tool") then
                    local category = item:GetAttribute("Category")
                    local name = item.Name:lower()
                    if category == "Key" or category == "Solution" or name:find("keycard") or name:find("solution") then
                        pcall(function()
                            item.Parent = workspace
                            print("Dropped backpack utility item: " .. item.Name)
                        end)
                    end
                end
            end
            
            if backpack then
                for _, item in ipairs(backpack:GetChildren()) do
                    checkAndDrop(item)
                end
            end
            if char then
                for _, item in ipairs(char:GetChildren()) do
                    checkAndDrop(item)
                end
            end
        end
    end
end)
