-- ฟังก์ชันจำลองการคลิก GUI
local function virtualClick(guiObject)
    if not guiObject then return end
    
    local absolutePosition = guiObject.AbsolutePosition
    local absoluteSize = guiObject.AbsoluteSize
    local centerPosition = absolutePosition + (absoluteSize / 2)
    
    VirtualInputManager:SendMouseMoveEvent(centerPosition.X, centerPosition.Y, game)
    task.wait(0.1)
    
    VirtualInputManager:SendMouseButtonEvent(centerPosition.X, centerPosition.Y, 0, true, game, 1)
    task.wait(0.05)
    VirtualInputManager:SendMouseButtonEvent(centerPosition.X, centerPosition.Y, 0, false, game, 1)
    task.wait(0.2)
end

-- ฟังก์ชันคลิกปุ่ม GUI แบบปลอดภัย (ใช้ firesignal ถ้ามี หากไม่มีจะใช้การจำลองการคลิก)
local function safeClick(guiObject)
    if not guiObject then return end
    local clicked = false
    pcall(function()
        if firesignal then
            firesignal(guiObject.MouseButton1Click)
            firesignal(guiObject.Activated)
            clicked = true
        end
    end)
    if not clicked then
        virtualClick(guiObject)
    end
end

-- ฟังก์ชันค้นหาปุ่มเปิด Locker (จากวัตถุช่องที่ 6 ของ workspace.Interactible)
local function findLockerPrompt()
    local target = workspace:FindFirstChild("Interactible") and workspace.Interactible:GetChildren()[6]
    if target then
        if target:IsA("ProximityPrompt") then
            return target
        end
        local prompt = target:FindFirstChildWhichIsA("ProximityPrompt") or target:FindFirstChildOfClass("ProximityPrompt")
        if prompt then
            return prompt
        end
        for _, desc in ipairs(target:GetDescendants()) do
            if desc:IsA("ProximityPrompt") then
                return desc
            end
        end
    end
    return nil
end

-- ฟังก์ชันส่งการกด Prompt
local function FireLootPrompt(prompt)
    if not prompt then return end
    pcall(function()
        prompt.RequiresLineOfSight = false
    end)
    if fireproximityprompt then
        fireproximityprompt(prompt)
    else
        pcall(function()
            prompt:InputHoldBegin()
            task.wait(prompt.HoldDuration or 0.1)
            prompt:InputHoldEnd()
        end)
    end
end

-- ฟังก์ชันฝากของเข้าล็อกเกอร์
local function DepositLocker()
    if isDepositing then return end
    isDepositing = true
    
    local success, err = pcall(function()
        local char = LocalPlayer.Character
        local backpack = LocalPlayer:FindFirstChild("Backpack")
        local humanoid = char and char:FindFirstChildOfClass("Humanoid")
        local hrp = char and char:FindFirstChild("HumanoidRootPart")
        if not backpack or not humanoid or not hrp then return end
        
        -- ปลดอาวุธทั้งหมดกลับเข้า Backpack ก่อน
        humanoid:UnequipTools()
        task.wait(0.2)
        
        -- ค้นหาไอเทมตามเกณฑ์ความหายาก
        local itemsToDeposit = {}
        for _, item in ipairs(backpack:GetChildren()) do
            if item:IsA("Tool") then
                local rarity = GetRarity(item)
                if rarity >= MIN_DEPOSIT_RARITY then
                    table.insert(itemsToDeposit, item)
                end
            end
        end
        
        if #itemsToDeposit == 0 then
            print("ไม่มีไอเทมตรงเกณฑ์ที่ต้องฝาก")
            return
        end
        
        -- วาร์ปกลับมาหน้าล็อกเกอร์ก่อนเริ่มฝากของ
        hrp.CFrame = getLockerCFrame()
        task.wait(0.5)
        
        local lockerPrompt = findLockerPrompt()
        if not lockerPrompt then
            warn("ไม่พบปุ่มตู้ Locker ใกล้ตัว")
            return
        end
        
        FireLootPrompt(lockerPrompt)
        task.wait(1.5)
        
        local lockerGui = PlayerGui:FindFirstChild("LockerGui")
        if not lockerGui then
            warn("ไม่พบ LockerGui")
            return
        end
        
        local scrollingFrame = lockerGui:FindFirstChild("Frame", true) 
            and lockerGui.Frame:FindFirstChild("Frame", true) 
            and lockerGui.Frame.Frame:FindFirstChild("Inset", true) 
            and lockerGui.Frame.Frame.Inset:FindFirstChild("ScrollingFrame", true)
            
        if not scrollingFrame then
            warn("ไม่พบ ScrollingFrame")
            return
        end
        
        print("กำลังเริ่มฝากของ " .. tostring(#itemsToDeposit) .. " ชิ้น เข้าล็อกเกอร์...")
        
        for _, item in ipairs(itemsToDeposit) do
            if not item or not item.Parent then continue end
            
            local targetSlot = nil
            for _, child in ipairs(scrollingFrame:GetChildren()) do
                if child:IsA("GuiObject") and child.Name:find("Card") then
                    local viewport = child:FindFirstChild("Frame") and child.Frame:FindFirstChild("ViewportFrame")
                    if viewport then
                        local isEmpty = true
                        for _, vChild in ipairs(viewport:GetChildren()) do
                            if vChild:IsA("Model") or vChild:IsA("BasePart") or vChild:IsA("MeshPart") or vChild:IsA("Folder") then
                                isEmpty = false
                                break
                            end
                        end
                        if isEmpty then
                            targetSlot = child
                            break
                        end
                    end
                end
            end
            
            if not targetSlot then
                warn("ล็อกเกอร์เต็มแล้ว!")
                break
            end
            
            humanoid:EquipTool(item)
            task.wait(0.3)
            
            -- เลื่อน ScrollingFrame ไปยังตำแหน่งของช่องฝากที่เลือกเพื่อให้แสดงผลบนหน้าจอและคลิกได้ถูกต้อง
            pcall(function()
                local relativeY = targetSlot.AbsolutePosition.Y - scrollingFrame.AbsolutePosition.Y + scrollingFrame.CanvasPosition.Y
                local targetScrollY = math.max(0, relativeY - (scrollingFrame.AbsoluteSize.Y / 2))
                scrollingFrame.CanvasPosition = Vector2.new(0, targetScrollY)
            end)
            task.wait(0.2)
            
            -- ค้นหาปุ่มจริงๆ ภายใน Card เพื่อคลิกฝาก
            local clickTarget = targetSlot:FindFirstChildOfClass("ImageButton") or targetSlot:FindFirstChild("Button") or targetSlot
            safeClick(clickTarget)
            task.wait(0.5)
        end
        
        local exitBtn = lockerGui:FindFirstChild("Exit", true) or lockerGui:FindFirstChild("Close", true)
        if exitBtn then
            safeClick(exitBtn)
            task.wait(0.5)
        end
        
        print("การฝากของเสร็จสมบูรณ์")
    end)
    if not success then
        warn("เกิดข้อผิดพลาดในการฝากของ: " .. tostring(err))
    end
    isDepositing = false
end

-- ฟังก์ชันสำหรับขายไอเทมตามเกรดที่เลือก
local function SellSelectedItems(isManual)
    local backpack = LocalPlayer:FindFirstChild("Backpack")
    if not backpack then return end
    
    local inventoryIndices = {}
    
    -- 1. ตรวจสอบอาวุธใน Backpack
    for _, item in ipairs(backpack:GetChildren()) do
        if item:IsA("Tool") then
            local rarity = GetRarity(item)
            local invIndex = item:GetAttribute("inventoryIndex")
            local isFav = item:GetAttribute("Favorited")
            local category = item:GetAttribute("Category")
            
            if invIndex and category == "Weapon" and SelectedSellRarities[rarity] and not isFav then
                table.insert(inventoryIndices, invIndex)
            end
        end
    end
    
    -- 2. ตรวจสอบอาวุธที่ติดตั้งอยู่ (Character)
    local char = LocalPlayer.Character
    if char then
        local equippedTool = char:FindFirstChildOfClass("Tool")
        if equippedTool then
            local rarity = GetRarity(equippedTool)
            local invIndex = equippedTool:GetAttribute("inventoryIndex")
            local isFav = equippedTool:GetAttribute("Favorited")
            local category = equippedTool:GetAttribute("Category")
            
            if invIndex and category == "Weapon" and SelectedSellRarities[rarity] and not isFav then
                table.insert(inventoryIndices, invIndex)
            end
        end
    end
    
    if #inventoryIndices == 0 then
        if isManual then
            print("ไม่มีปืนเกรดที่เลือกขายในกระเป๋า")
        end
        return
    end
    
    -- 3. เรียกใช้งาน RemoteFunction เพื่อขาย
    pcall(function()
        local remotes = game:GetService("ReplicatedStorage"):FindFirstChild("Remotes")
        local sellRemote = remotes and remotes:FindFirstChild("ClientSellRequest")
        
        if sellRemote and sellRemote:IsA("RemoteFunction") then
            print("กำลังขายปืนจำนวน " .. tostring(#inventoryIndices) .. " ชิ้น...")
            local payout = sellRemote:InvokeServer(inventoryIndices)
            if payout then
                print("ขายสำเร็จ! ได้รับเงิน: " .. tostring(payout))
            end
        else
            warn("ไม่พบ RemoteFunction: ClientSellRequest")
        end
    end)
end

